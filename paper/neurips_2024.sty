% neurips_2024.sty - Simplified NeurIPS-style for arXiv preprint
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2024}[2024/01/01 NeurIPS 2024 preprint style]

% Options
\newif\if@preprint\@preprinttrue
\newif\if@nonatbib\@nonatbibfalse
\DeclareOption{preprint}{\@preprinttrue}
\DeclareOption{final}{\@preprintfalse}
\DeclareOption{nonatbib}{\@nonatbibtrue}
\ProcessOptions\relax

% Page geometry
\RequirePackage{geometry}
\geometry{
  letterpaper,
  textwidth=6.5in,
  textheight=9in,
  top=1in,
  headheight=14pt,
  headsep=0.25in,
  footskip=0.3in,
}

% Font settings
\renewcommand{\rmdefault}{ptm}
\renewcommand{\sfdefault}{phv}
\renewcommand{\ttdefault}{pcr}

% Natbib
\if@nonatbib\else
  \RequirePackage[sort&compress,square,comma,numbers]{natbib}
  \bibliographystyle{abbrvnat}
\fi

% Hyperref
\RequirePackage[colorlinks=true,citecolor=blue,urlcolor=blue,linkcolor=red]{hyperref}
\RequirePackage{url}

% Section formatting
\RequirePackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection}{1em}{}

% Header/footer
\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhead{}
\fancyfoot{}
\fancyfoot[C]{\thepage}
\renewcommand{\headrulewidth}{0pt}

% Caption
\RequirePackage[font=small,labelfont=bf]{caption}

% Spacing
\renewcommand{\baselinestretch}{1.0}
\setlength{\parskip}{0.5ex plus 0.1ex minus 0.1ex}
\setlength{\parindent}{1em}

% Float placement
\renewcommand{\topfraction}{0.9}
\renewcommand{\bottomfraction}{0.8}
\renewcommand{\textfraction}{0.1}
\renewcommand{\floatpagefraction}{0.8}

\endinput
